{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Newton Companion",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "opener:default",
    "log:default"
  ]
}
